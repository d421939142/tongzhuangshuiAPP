# 运行模式：production 或 mock
NODE_ENV=production

# 服务器端口
PORT=3000

# MongoDB 连接地址
# 本地测试：mongodb://localhost:27017
# MongoDB Atlas：mongodb+srv://user:pass@cluster.mongodb.net/water_delivery
# 如果没有 MongoDB，改成下面这行启用内存模式（数据重启丢失）
# MONGODB_URI=mock://localhost:27017
MONGODB_URI=mongodb://localhost:27017

# JWT 密钥（必须改成随机字符串）
JWT_SECRET=your_super_secret_key_change_this_in_production

# 文件上传目录
UPLOAD_DIR=./uploads
