/* pages/admin/index.wxss */
.admin-page {
  background: #F0F9FF;
  min-height: 100vh;
}

.admin-header {
  background: linear-gradient(145deg, #0C4A6E, #0EA5E9);
  padding: 40rpx 32rpx 60rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.ah-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFF;
  margin-bottom: 32rpx;
}

.ah-stats {
  display: flex;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 24rpx 0;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFF;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

.stat-divider {
  width: 1rpx;
  background: rgba(255,255,255,0.2);
  margin: 8rpx 0;
}

/* 快捷菜单 */
.quick-menu {
  margin: -20rpx 24rpx 0;
  background: #FFF;
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(14,165,233,0.1);
}

.qm-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
  position: relative;
}

.qm-item:last-child {
  border-bottom: none;
}

.qm-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.qm-icon-amber { background: #FEF3C7; }
.qm-icon-blue { background: #E0F2FE; }
.qm-icon-teal { background: #CCFBF1; }
.qm-icon-green { background: #DCFCE7; }

.qm-img {
  width: 44rpx;
  height: 44rpx;
}

.qm-info {
  flex: 1;
}

.qm-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  display: block;
}

.qm-sub {
  font-size: 24rpx;
  color: #94A3B8;
  display: block;
  margin-top: 4rpx;
}

.qm-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
}

.qm-badge {
  background: #EF4444;
  color: #FFF;
  font-size: 22rpx;
  font-weight: 700;
  min-width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}
