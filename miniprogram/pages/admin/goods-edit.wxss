/* pages/admin/goods-edit.wxss */
.goods-edit-page {
  background: #F0F9FF;
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.section-block {
  background: #FFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(14,165,233,0.07);
}

.block-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0C4A6E;
  margin-bottom: 16rpx;
}

/* 图片上传 */
.img-upload {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.upload-preview {
  width: 200rpx;
  height: 200rpx;
}

.upload-placeholder {
  width: 200rpx;
  height: 200rpx;
  background: #F1F5F9;
  border-radius: 16rpx;
  border: 3rpx dashed #CBD5E1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 64rpx;
  color: #CBD5E1;
  line-height: 1;
}

.upload-tip {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

/* 描述 */
.desc-input {
  width: 100%;
  min-height: 160rpx;
  font-size: 26rpx;
  color: #1E293B;
  padding: 16rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.save-btn {
  width: 100%;
}
