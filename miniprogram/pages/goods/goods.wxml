<!-- pages/goods/goods.wxml - 商品列表页 -->
<view class="goods-page">
  <!-- 搜索框 -->
  <view class="search-bar">
    <image src="/assets/icons/search.png" mode="aspectFit" class="search-icon" />
    <input
      class="search-input"
      placeholder="搜索商品名称..."
      value="{{keyword}}"
      bindinput="onSearch"
      confirm-type="search"
    />
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="category-scroll" scroll-x>
    <view
      class="cat-item {{activeCategory === item ? 'cat-active' : ''}}"
      wx:for="{{categories}}"
      wx:key="*this"
      bindtap="filterCategory"
      data-cat="{{item}}"
    >{{item}}</view>
  </scroll-view>

  <!-- 商品网格 -->
  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view class="goods-grid" wx:else>
    <view
      class="goods-grid-item"
      wx:for="{{filteredGoods}}"
      wx:key="_id"
      bindtap="goDetail"
      data-id="{{item._id}}"
    >
      <view class="ggi-img-wrap">
        <image class="ggi-img" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="ggi-category tag tag-blue">{{item.category}}</view>
      </view>
      <view class="ggi-info">
        <text class="ggi-name">{{item.name}}</text>
        <text class="ggi-spec">{{item.spec}}</text>
        <view class="ggi-bottom">
          <text class="ggi-price price">¥{{item.price}}</text>
          <view class="ggi-add" catchtap="addToCart" data-item="{{item}}">+</view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{filteredGoods.length === 0}}">
      <text class="empty-text">没有找到相关商品</text>
    </view>
  </view>

  <!-- 购物车悬浮 -->
  <view class="cart-fab" wx:if="{{cartCount > 0}}" bindtap="goOrder">
    <view class="cart-badge">{{cartCount}}</view>
    <text class="cart-total">¥{{cartTotal}}</text>
    <text class="cart-go">去结算</text>
  </view>
</view>
