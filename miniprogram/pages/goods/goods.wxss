/* pages/goods/goods.wxss */
.goods-page {
  background: #F0F9FF;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 搜索 */
.search-bar {
  display: flex;
  align-items: center;
  background: #FFF;
  margin: 16rpx 24rpx;
  border-radius: 100rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(14,165,233,0.08);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.4;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #1E293B;
}

/* 分类 */
.category-scroll {
  padding: 8rpx 24rpx;
  white-space: nowrap;
}

.cat-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  color: #64748B;
  background: #FFF;
  border: 2rpx solid #E2E8F0;
}

.cat-active {
  color: #0EA5E9;
  background: #E0F2FE;
  border-color: #0EA5E9;
  font-weight: 600;
}

/* 商品网格 */
.goods-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 16rpx;
  gap: 16rpx;
}

.goods-grid-item {
  width: calc(50% - 8rpx);
  background: #FFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(14,165,233,0.07);
}

.ggi-img-wrap {
  position: relative;
}

.ggi-img {
  width: 100%;
  height: 280rpx;
}

.ggi-category {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
}

.ggi-info {
  padding: 16rpx;
}

.ggi-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ggi-spec {
  font-size: 22rpx;
  color: #94A3B8;
  display: block;
  margin: 4rpx 0 12rpx;
}

.ggi-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ggi-price {
  font-size: 30rpx;
  font-weight: 700;
}

.ggi-add {
  width: 52rpx;
  height: 52rpx;
  background: #0EA5E9;
  color: #FFF;
  font-size: 36rpx;
  font-weight: 300;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

/* 购物车悬浮 */
.cart-fab {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  background: linear-gradient(135deg, #0C4A6E, #0EA5E9);
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  gap: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(14,165,233,0.45);
}

.cart-badge {
  background: #F59E0B;
  color: #FFF;
  font-size: 22rpx;
  font-weight: 700;
  min-width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.cart-total {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFF;
}

.cart-go {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.2);
  padding: 10rpx 24rpx;
  border-radius: 100rpx;
}
