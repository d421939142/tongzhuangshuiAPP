/* pages/index/index.wxss */

.index-page {
  background: #F0F9FF;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* ==================== Banner ==================== */
.banner {
  background: linear-gradient(145deg, #0C4A6E 0%, #0EA5E9 100%);
  padding: 60rpx 32rpx 80rpx;
  position: relative;
  overflow: hidden;
  border-radius: 0 0 40rpx 40rpx;
}

.banner-content {
  position: relative;
  z-index: 2;
}

.banner-greeting {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  margin-bottom: 8rpx;
}

.banner-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
}

.banner-img {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  width: 200rpx;
  height: 160rpx;
  z-index: 2;
  opacity: 0.9;
}

.wave-decor {
  position: absolute;
  bottom: -20rpx;
  left: -40rpx;
  right: -40rpx;
  height: 80rpx;
  background: #F0F9FF;
  border-radius: 50% 50% 0 0;
}

/* ==================== 快速入口 ==================== */
.quick-entry {
  display: flex;
  justify-content: space-around;
  margin: -24rpx 24rpx 20rpx;
  position: relative;
  z-index: 3;
  padding: 28rpx 0;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-icon-blue { background: #E0F2FE; }
.quick-icon-amber { background: #FEF3C7; }
.quick-icon-teal { background: #CCFBF1; }
.quick-icon-red { background: #FEE2E2; }

.qi-img {
  width: 52rpx;
  height: 52rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}

/* ==================== section header ==================== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 24rpx 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0C4A6E;
}

.section-more {
  font-size: 24rpx;
  color: #0EA5E9;
}

/* ==================== 上次订单 ==================== */
.last-order-section {
  margin-bottom: 8rpx;
}

.last-order-card {
  margin: 0 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.lo-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.lo-info {
  flex: 1;
}

.lo-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  display: block;
}

.lo-qty {
  font-size: 24rpx;
  color: #64748B;
  display: block;
  margin-top: 6rpx;
}

.lo-time {
  font-size: 22rpx;
  color: #94A3B8;
  display: block;
  margin-top: 4rpx;
}

.lo-btn {
  flex-shrink: 0;
}

.lo-rebuy {
  font-size: 24rpx !important;
  padding: 16rpx 24rpx !important;
  width: auto !important;
  min-width: 160rpx;
}

/* ==================== 商品列表 ==================== */
.goods-section {
  margin-top: 8rpx;
}

.goods-list {
  padding: 0 24rpx;
}

.goods-card {
  display: flex;
  align-items: stretch;
  gap: 0;
  padding: 0;
  overflow: hidden;
  margin-bottom: 20rpx;
  position: relative;
}

.gc-color-bar {
  width: 10rpx;
  flex-shrink: 0;
  border-radius: 0;
}

.gc-img {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  object-fit: cover;
}

.gc-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.gc-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1E293B;
  line-height: 1.3;
}

.gc-desc {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 6rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.gc-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.gc-spec {
  font-size: 22rpx;
  color: #94A3B8;
}

.gc-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.gc-unit {
  font-size: 22rpx;
  color: #94A3B8;
  font-weight: 400;
}

.gc-buy-btn {
  background: #0EA5E9;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 28rpx;
  border-radius: 100rpx;
  border: none;
  line-height: 1.4;
}

.gc-buy-btn::after {
  border: none;
}

/* ==================== 购物车悬浮 ==================== */
.cart-fab {
  position: fixed;
  bottom: 130rpx;
  left: 40rpx;
  right: 40rpx;
  background: linear-gradient(135deg, #0C4A6E, #0EA5E9);
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(14, 165, 233, 0.45);
  z-index: 100;
}

.cart-fab-icon {
  position: relative;
  margin-right: 20rpx;
}

.cart-img {
  width: 56rpx;
  height: 56rpx;
  filter: brightness(10);
}

.cart-badge {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  background: #F59E0B;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 700;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-fab-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart-fab-total {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.cart-fab-tip {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.2);
  padding: 10rpx 24rpx;
  border-radius: 100rpx;
}
